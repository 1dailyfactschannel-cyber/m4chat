{
  "name": "m4chat-electron",
  "version": "1.0.0",
  "description": "m4chat desktop application",
  "main": "./out/main/index.js",
  "author": "you",
  "homepage": "https://github.com/you/m4chat-electron",
  "scripts": {
    "dev": "electron-vite dev",
    "build": "electron-vite build",
